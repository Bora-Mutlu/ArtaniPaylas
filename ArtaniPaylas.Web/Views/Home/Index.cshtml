@{
    ViewData["Title"] = "Ana Sayfa";
}

<section class="container mx-auto py-12 lg:py-20">
    <div class="row align-items-center g-5">
        <div class="col-lg-6">
            <span class="inline-block py-1 px-3 rounded-full bg-emerald-100 text-emerald-700 text-sm font-bold tracking-wider uppercase mb-4">
                Sosyal Fayda Odaklı Platform
            </span>
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
                Artanı Paylaş ile israfı azalt, <span class="text-emerald-600">dayanışmayı büyüt.</span>
            </h1>
            <p class="text-lg text-gray-600 mb-8 leading-relaxed">
                Amacımız, kullanılabilir durumdaki fazla gıdayı güvenli şekilde ihtiyaç sahiplerine ulaştırmak.
                Kullanıcılarımızla birlikte daha sürdürülebilir ve daha adil bir paylaşım ağı kuruyoruz.
            </p>

            <div class="d-flex flex-wrap gap-3 mb-8">
                <a asp-controller="Listings" asp-action="Index" class="ap-cta ap-cta-primary text-decoration-none">
                    İlanları Gör
                </a>
                <a asp-controller="Listings" asp-action="Create" class="ap-cta ap-cta-secondary text-decoration-none">
                    İlan Oluştur
                </a>
            </div>

            <div class="row g-3 border-top border-gray-200 pt-6 mt-2">
                <div class="col-sm-4">
                    <div class="text-sm text-gray-500">Hedef</div>
                    <strong class="text-gray-900">İsrafı Azaltmak</strong>
                </div>
                <div class="col-sm-4">
                    <div class="text-sm text-gray-500">Yaklaşım</div>
                    <strong class="text-gray-900">Güvenli Akış</strong>
                </div>
                <div class="col-sm-4">
                    <div class="text-sm text-gray-500">Sonuç</div>
                    <strong class="text-gray-900">Hızlı Eşleşme</strong>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="ap-home-photo-wrap">
                <div class="ap-home-photo" role="img" aria-label="Dayanışma ve Paylaşım görsel alanı"></div>
            </div>
        </div>
    </div>
</section>

<section class="container mx-auto py-10">
    <div class="row g-4">
        <div class="col-md-4">
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-100 border-b-4 border-b-emerald-500">
                <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-lg flex items-center justify-center mb-6 text-2xl">
                    🎯
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-3">Sitemizin Amacı</h2>
                <p class="text-gray-600 leading-relaxed">
                    İhtiyaç sahibi bireylerin kullanılabilir gıdaya erişimini dijital araçlarla kolaylaştırmak ve hızlandırmak.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-100 border-b-4 border-b-emerald-500">
                <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-lg flex items-center justify-center mb-6 text-2xl">
                    ⭐
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-3">Temel Hedeflerimiz</h2>
                <p class="text-gray-600 leading-relaxed">
                    Güvenli paylaşım, şeffaf süreç yönetimi ve yerel dayanışmayı artırarak güçlü bir topluluk etkisi oluşturmak.
                </p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 h-100 border-b-4 border-b-emerald-500">
                <div class="w-12 h-12 bg-emerald-100 text-emerald-600 rounded-lg flex items-center justify-center mb-6 text-2xl">
                    🌱
                </div>
                <h2 class="text-xl font-bold text-gray-900 mb-3">Neden Artanı Paylaş?</h2>
                <p class="text-gray-600 leading-relaxed">
                    Çünkü dünyamızın kaynakları sınırlı; fazla gıda çöpe değil, saygın bir şekilde ihtiyaç sahibine ulaşmalı.
                </p>
            </div>
        </div>
    </div>
</section>

<section class="container mx-auto py-12 mb-10">
    <div class="bg-emerald-50 rounded-[2.5rem] p-10 md:p-16 text-center shadow-inner">
        <h2 class="text-3xl font-extrabold text-gray-900 mb-10">Nasıl Çalışır?</h2>

        <div class="row g-5">
            <div class="col-md-4 relative">
                <div class="w-16 h-16 mx-auto bg-white text-emerald-600 font-bold text-2xl rounded-full flex items-center justify-center shadow-md mb-4">1</div>
                <h3 class="font-bold text-lg text-gray-900 mb-2">İlan Oluştur</h3>
                <p class="text-gray-600 text-sm">Elinizdeki fazla veya paylaşılabilir durumdaki gıdaları sisteme ekleyin.</p>
            </div>
            <div class="col-md-4 relative">
                <div class="w-16 h-16 mx-auto bg-white text-emerald-600 font-bold text-2xl rounded-full flex items-center justify-center shadow-md mb-4">2</div>
                <h3 class="font-bold text-lg text-gray-900 mb-2">Talep ve Eşleşme</h3>
                <p class="text-gray-600 text-sm">İhtiyaç sahipleri veya kurumlar ilanlara talep göndersin ve eşleşme sağlansın.</p>
            </div>
            <div class="col-md-4 relative">
                <div class="w-16 h-16 mx-auto bg-white text-emerald-600 font-bold text-2xl rounded-full flex items-center justify-center shadow-md mb-4">3</div>
                <h3 class="font-bold text-lg text-gray-900 mb-2">Güvenli Teslimat</h3>
                <p class="text-gray-600 text-sm">Sistem üzerinden onaylanan işlem sonrası gıda güvenle sahibine ulaşsın.</p>
            </div>
        </div>
    </div>
</section>
