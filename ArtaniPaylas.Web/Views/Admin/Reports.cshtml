@model IEnumerable<ArtaniPaylas.Core.Entities.Report>
@{
    ViewData["Title"] = "Şikayet Yönetimi";
    Layout = "_AdminLayout";
}

<section class="mb-8">
    <h1 class="text-4xl font-extrabold text-on-surface tracking-tight">Şikayet ve Rapor İncelemeleri</h1>
    <p class="text-on-surface-variant mt-2 text-lg">Kullanıcı ve ilan şikayetlerini değerlendirip sonuçlandırın.</p>
</section>

<section class="bg-surface-container-low p-4 md:p-6 rounded-xl">
    <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="text-xl font-bold text-on-surface">Raporlar</h2>
        <a href="/Admin" class="text-sm px-4 py-2 rounded-lg bg-surface-container-lowest text-on-surface hover:bg-surface transition-colors">Panele Dön</a>
    </div>

    <div class="overflow-x-auto rounded-xl bg-surface-container-lowest">
        <table class="min-w-full text-sm">
            <thead class="text-left bg-surface-container-low text-[0.6875rem] uppercase tracking-wider text-slate-500 font-bold">
                <tr>
                    <th class="px-4 py-3">No</th>
                    <th class="px-4 py-3">Şikayet Eden</th>
                    <th class="px-4 py-3">Hedef</th>
                    <th class="px-4 py-3">Açıklama</th>
                    <th class="px-4 py-3">Durum</th>
                    <th class="px-4 py-3">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var report in Model)
                {
                    <tr class="border-b border-outline-variant/15 hover:bg-surface-container-low transition-colors align-top">
                        <td class="px-4 py-3 font-semibold text-on-surface">@report.Id</td>
                        <td class="px-4 py-3 text-on-surface-variant">
                            <div class="font-semibold text-on-surface">@(report.Reporter?.FullName ?? report.Reporter?.UserName ?? "Silinmiş Kullanıcı")</div>
                            <div class="text-xs">@(report.Reporter?.Email ?? "-")</div>
                        </td>
                        <td class="px-4 py-3">
                            @if (report.ReportedUserId != null)
                            {
                                <span class="inline-flex items-center rounded-full bg-secondary-container/50 text-secondary px-3 py-1 text-xs font-bold">Kullanıcı</span>
                                <div class="mt-1 text-on-surface-variant text-xs">@(report.ReportedUser?.Email ?? "Silinmiş Hedef Kullanıcı")</div>
                            }
                            else if (report.ReportedListingId != null)
                            {
                                <span class="inline-flex items-center rounded-full bg-secondary-container/50 text-secondary px-3 py-1 text-xs font-bold">İlan</span>
                                <div class="mt-1 text-xs"><a class="text-primary hover:underline" href="/Admin/Reports/Review/@report.Id">İlanı İncele (No: @report.ReportedListingId)</a></div>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full bg-surface-container-high text-on-surface-variant px-3 py-1 text-xs font-bold">Genel Sistem Raporu</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-on-surface-variant">@report.Reason</td>
                        <td class="px-4 py-3">
                            @if (report.Status == ArtaniPaylas.Core.Enums.ReportStatus.Pending)
                            {
                                <span class="inline-flex items-center rounded-full bg-error-container text-on-error-container px-3 py-1 text-xs font-bold">Bekliyor</span>
                            }
                            else if (report.Status == ArtaniPaylas.Core.Enums.ReportStatus.Resolved)
                            {
                                <span class="inline-flex items-center rounded-full bg-tertiary-container/20 text-tertiary px-3 py-1 text-xs font-bold">Çözüldü</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full bg-surface-container-high text-on-surface-variant px-3 py-1 text-xs font-bold">@report.Status.ToDisplayText()</span>
                            }
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2 flex-wrap">
                                @if (report.ReportedListingId != null)
                                {
                                    <a href="/Admin/Reports/Review/@report.Id" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-primary text-on-primary hover:opacity-90 transition-opacity no-underline">İncele</a>
                                }

                                @if (report.Status == ArtaniPaylas.Core.Enums.ReportStatus.Pending)
                                {
                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Reviewed" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-secondary text-on-secondary hover:opacity-90 transition-opacity">İncelendi</button>
                                    </form>

                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Resolved" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-tertiary text-on-tertiary hover:opacity-90 transition-opacity">Çözüldü</button>
                                    </form>

                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Dismissed" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-error text-on-error hover:opacity-90 transition-opacity">Reddet</button>
                                    </form>
                                }

                                @if (report.Status == ArtaniPaylas.Core.Enums.ReportStatus.Reviewed)
                                {
                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Resolved" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-tertiary text-on-tertiary hover:opacity-90 transition-opacity">Çözüldü</button>
                                    </form>

                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Dismissed" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-error text-on-error hover:opacity-90 transition-opacity">Reddet</button>
                                    </form>

                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Pending" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container-high text-on-surface hover:opacity-90 transition-opacity">Beklemeye Al</button>
                                    </form>
                                }

                                @if (report.Status == ArtaniPaylas.Core.Enums.ReportStatus.Resolved)
                                {
                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Dismissed" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-error text-on-error hover:opacity-90 transition-opacity">Çözümü Reddet</button>
                                    </form>

                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Pending" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container-high text-on-surface hover:opacity-90 transition-opacity">Beklemeye Al</button>
                                    </form>
                                }

                                @if (report.Status == ArtaniPaylas.Core.Enums.ReportStatus.Dismissed)
                                {
                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Reviewed" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-secondary text-on-secondary hover:opacity-90 transition-opacity">İncelemeye Al</button>
                                    </form>

                                    <form action="/Admin/UpdateReportStatus" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@report.Id" />
                                        <input type="hidden" name="expectedCurrentStatus" value="@report.Status" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ReportStatus.Pending" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-surface-container-high text-on-surface hover:opacity-90 transition-opacity">Beklemeye Al</button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

