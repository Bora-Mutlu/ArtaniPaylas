@model IEnumerable<ArtaniPaylas.Core.Entities.Listing>
@{
    ViewData["Title"] = "İlan Yönetimi";
    Layout = "_AdminLayout";
}

<section class="mb-8">
    <h1 class="text-4xl font-extrabold text-on-surface tracking-tight">İlan Moderasyonu</h1>
    <p class="text-on-surface-variant mt-2 text-lg">Yayınlanan ilanları görüntüleyin, durumlarını güncelleyip moderasyon akışını yönetin.</p>
</section>

<section class="bg-surface-container-low p-4 md:p-6 rounded-xl">
    <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="text-xl font-bold text-on-surface">İlanlar</h2>
        <a href="/Admin" class="text-sm px-4 py-2 rounded-lg bg-surface-container-lowest text-on-surface hover:bg-surface transition-colors">Panele Dön</a>
    </div>

    <div class="overflow-x-auto rounded-xl bg-surface-container-lowest">
        <table class="min-w-full text-sm">
            <thead class="text-left bg-surface-container-low text-[0.6875rem] uppercase tracking-wider text-slate-500 font-bold">
                <tr>
                    <th class="px-4 py-3">No</th>
                    <th class="px-4 py-3">Başlık</th>
                    <th class="px-4 py-3">Sahibi</th>
                    <th class="px-4 py-3">Durum</th>
                    <th class="px-4 py-3">Tarih</th>
                    <th class="px-4 py-3">İşlem</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var listing in Model)
                {
                    <tr class="border-b border-outline-variant/15 hover:bg-surface-container-low transition-colors">
                        <td class="px-4 py-3 font-semibold text-on-surface">@listing.Id</td>
                        <td class="px-4 py-3">
                            <a href="/Listings/Details/@listing.Id" target="_blank" class="text-primary font-semibold hover:underline">@listing.Title</a>
                        </td>
                        <td class="px-4 py-3 text-on-surface-variant">@listing.OwnerUser?.Email</td>
                        <td class="px-4 py-3">
                            @if (listing.Status == ArtaniPaylas.Core.Enums.ListingStatus.Active)
                            {
                                <span class="inline-flex items-center rounded-full bg-tertiary-container/20 text-tertiary px-3 py-1 text-xs font-bold">@listing.Status.ToDisplayText()</span>
                            }
                            else if (listing.Status == ArtaniPaylas.Core.Enums.ListingStatus.Suspended)
                            {
                                <span class="inline-flex items-center rounded-full bg-error-container text-on-error-container px-3 py-1 text-xs font-bold">@listing.Status.ToDisplayText()</span>
                            }
                            else
                            {
                                <span class="inline-flex items-center rounded-full bg-secondary-container/40 text-secondary px-3 py-1 text-xs font-bold">@listing.Status.ToDisplayText()</span>
                            }
                        </td>
                        <td class="px-4 py-3 text-on-surface-variant">@listing.CreatedAt.ToShortDateString()</td>
                        <td class="px-4 py-3">
                            <div class="flex items-center gap-2 flex-wrap">
                                @if (listing.Status == ArtaniPaylas.Core.Enums.ListingStatus.Active)
                                {
                                    <form action="/Admin/ModerateListing" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@listing.Id" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ListingStatus.Suspended" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-error text-on-error hover:opacity-90 transition-opacity">Askıya Al</button>
                                    </form>
                                }
                                else
                                {
                                    <form action="/Admin/ModerateListing" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@listing.Id" />
                                        <input type="hidden" name="status" value="@ArtaniPaylas.Core.Enums.ListingStatus.Active" />
                                        <button type="submit" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-tertiary text-on-tertiary hover:opacity-90 transition-opacity">Aktife Al</button>
                                    </form>
                                }

                                <a href="/Listings/Details/@listing.Id" target="_blank" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-primary text-on-primary hover:opacity-90 transition-opacity no-underline">Detay</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>

