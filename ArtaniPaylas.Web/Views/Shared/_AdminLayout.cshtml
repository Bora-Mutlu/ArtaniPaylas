@{
    var path = Context.Request.Path.Value?.ToLowerInvariant() ?? string.Empty;
    var isDashboard = path == "/admin" || path == "/admin/index";
    var isUsers = path.StartsWith("/admin/users");
    var isListings = path.StartsWith("/admin/listings");
    var isReports = path.StartsWith("/admin/reports");
    var isSettings = path.StartsWith("/admin/settings");

    var adminName = User?.Identity?.Name;
    if (string.IsNullOrWhiteSpace(adminName))
    {
        adminName = "Yönetici";
    }

    var activeLink = "flex items-center gap-3 px-4 py-3 text-blue-700 font-bold border-r-4 border-blue-700 bg-slate-200/50 transition-all duration-200";
    var passiveLink = "flex items-center gap-3 px-4 py-3 text-slate-500 font-medium hover:bg-slate-200/50 transition-colors";
}
<!DOCTYPE html>
<html class="light" lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Paneli</title>

    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />

    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "on-primary-fixed-variant": "#0040a2",
                        "outline-variant": "#c3c6d6",
                        "error": "#ba1a1a",
                        "tertiary-container": "#006846",
                        "outline": "#737685",
                        "surface-tint": "#0c56d0",
                        "on-secondary": "#ffffff",
                        "on-secondary-fixed-variant": "#3a485b",
                        "primary-fixed-dim": "#b2c5ff",
                        "on-error-container": "#93000a",
                        "on-primary": "#ffffff",
                        "background": "#f7f9fb",
                        "on-secondary-fixed": "#0d1c2e",
                        "secondary-container": "#d5e3fc",
                        "tertiary": "#004e33",
                        "tertiary-fixed-dim": "#4edea3",
                        "on-tertiary-fixed-variant": "#005236",
                        "on-tertiary-container": "#5debaf",
                        "surface-container": "#eceef0",
                        "inverse-primary": "#b2c5ff",
                        "on-surface": "#191c1e",
                        "on-error": "#ffffff",
                        "inverse-on-surface": "#eff1f3",
                        "primary": "#003d9b",
                        "surface-variant": "#e0e3e5",
                        "secondary": "#515f74",
                        "surface": "#f7f9fb",
                        "tertiary-fixed": "#6ffbbe",
                        "surface-container-highest": "#e0e3e5",
                        "on-background": "#191c1e",
                        "surface-dim": "#d8dadc",
                        "secondary-fixed-dim": "#b9c7df",
                        "surface-container-low": "#f2f4f6",
                        "on-primary-container": "#c4d2ff",
                        "on-primary-fixed": "#001848",
                        "on-tertiary": "#ffffff",
                        "primary-container": "#0052cc",
                        "on-surface-variant": "#434654",
                        "primary-fixed": "#dae2ff",
                        "surface-container-high": "#e6e8ea",
                        "surface-bright": "#f7f9fb",
                        "error-container": "#ffdad6",
                        "secondary-fixed": "#d5e3fc",
                        "on-secondary-container": "#57657a",
                        "surface-container-lowest": "#ffffff",
                        "inverse-surface": "#2d3133",
                        "on-tertiary-fixed": "#002113"
                    },
                    borderRadius: {
                        DEFAULT: "0.125rem",
                        lg: "0.25rem",
                        xl: "0.5rem",
                        full: "0.75rem"
                    },
                    fontFamily: {
                        headline: ["Inter"],
                        body: ["Inter"],
                        label: ["Inter"]
                    }
                }
            }
        };
    </script>

    <style>
        body { font-family: 'Inter', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
        .ap-gradient-primary { background-image: linear-gradient(135deg, #003d9b 0%, #0052cc 100%); }
    </style>
</head>
<body class="bg-surface text-on-surface antialiased overflow-x-hidden">
    <aside class="hidden md:flex fixed left-0 top-0 h-screen z-40 w-64 flex-col bg-slate-100/80 backdrop-blur-xl transition-all duration-300">
        <div class="p-8">
            <h1 class="text-xl font-black text-blue-900 tracking-tight">Canvas Admin</h1>
            <p class="text-[0.6875rem] tracking-wider uppercase font-semibold text-slate-500 mt-1">Kurumsal Yönetim</p>
        </div>

        <nav class="flex-1 px-4 space-y-2 mt-4">
            <a class="@(isDashboard ? activeLink : passiveLink)" href="/Admin">
                <span class="material-symbols-outlined">dashboard</span>
                <span class="text-[0.6875rem] tracking-wider uppercase">Panel</span>
            </a>
            <a class="@(isUsers ? activeLink : passiveLink)" href="/Admin/Users">
                <span class="material-symbols-outlined">group</span>
                <span class="text-[0.6875rem] tracking-wider uppercase">Kullanıcı Yönetimi</span>
            </a>
            <a class="@(isListings ? activeLink : passiveLink)" href="/Admin/Listings">
                <span class="material-symbols-outlined">folder_open</span>
                <span class="text-[0.6875rem] tracking-wider uppercase">İlan Moderasyonu</span>
            </a>
            <a class="@(isReports ? activeLink : passiveLink)" href="/Admin/Reports">
                <span class="material-symbols-outlined">monitoring</span>
                <span class="text-[0.6875rem] tracking-wider uppercase">Şikayet İncelemeleri</span>
            </a>
            <a class="@(isSettings ? activeLink : passiveLink)" href="/Admin/Settings">
                <span class="material-symbols-outlined">settings</span>
                <span class="text-[0.6875rem] tracking-wider uppercase">Ayarlar</span>
            </a>
        </nav>

        <div class="p-4 space-y-1">
            <a href="/Admin/Reports" class="w-full ap-gradient-primary text-on-primary py-3 rounded-xl font-semibold text-sm mb-4 shadow-lg shadow-primary/20 hover:scale-[0.98] transition-transform inline-flex items-center justify-center">
                Yeni Rapor
            </a>
            <a class="flex items-center gap-3 px-4 py-2 text-slate-500 font-medium hover:bg-slate-200/50 transition-colors rounded-lg" href="/">
                <span class="material-symbols-outlined">logout</span>
                <span class="text-xs font-semibold">Siteye Dön</span>
            </a>
            <form action="/Account/Logout" method="post" class="px-4 py-1">
                @Html.AntiForgeryToken()
                <button type="submit" class="w-full text-left text-xs font-semibold text-error hover:text-on-error hover:bg-error rounded-lg px-3 py-2 transition-colors">
                    Hesaptan Çıkış
                </button>
            </form>
        </div>
    </aside>

    <header class="fixed top-0 z-30 h-16 w-full md:ml-64 md:max-w-[calc(100%-16rem)] px-4 md:px-8 bg-slate-50/90 backdrop-blur-md flex items-center justify-between">
        <h2 class="text-on-surface font-bold text-xl">@ViewData["Title"]</h2>

        <div class="flex items-center gap-3 md:gap-6">
            <a href="/Admin/Reports" class="text-slate-600 hover:text-primary transition-colors" title="Bildirimler">
                <span class="material-symbols-outlined">notifications</span>
            </a>
            <a href="/Admin/Users" class="text-slate-600 hover:text-primary transition-colors" title="Mesajlar">
                <span class="material-symbols-outlined">mail</span>
            </a>

            <div class="hidden sm:flex items-center gap-3">
                <div class="text-right">
                    <p class="text-xs font-bold text-on-surface">@adminName</p>
                    <p class="text-[10px] text-slate-500">Süper Yönetici</p>
                </div>
                <img alt="Admin profil" class="h-10 w-10 rounded-full object-cover border-2 border-primary/10" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAXjJthJUDfhC_50wd7IqukdQYEdOusZU2W8nUlsetgcfDK7eod5FJJ7HAoadtrrRYlmh9nVZNguJR1XsnFDxrVecwE3G90ZzvJu26WpEl_F8vN_AEubZB6O_aaSHgo8L86siNeuWjgvhTCJOHyWTpiHVz03Z-dPfi-tuBd5POCfszOcx-LqYChNFzXBfGVXqOYOMA4an1q4rOiUBi1QGaq_hjIoWVjBNDQjeKr8g2qvqkA3s_BWtjljYf01mkStOHHf929f_x6x90" />
                <form action="/Account/Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="text-slate-500 font-bold text-xs hover:text-error transition-colors">Çıkış</button>
                </form>
            </div>
        </div>
    </header>

    <main class="pt-24 pb-12 px-4 md:px-8 md:ml-64 min-h-screen">
        <div class="max-w-7xl mx-auto">
            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="mb-6 bg-tertiary-container/10 text-tertiary px-4 py-3 rounded-xl">
                    @successMessage
                </div>
            }
            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="mb-6 bg-error-container/40 text-on-error-container px-4 py-3 rounded-xl">
                    @errorMessage
                </div>
            }

            @RenderBody()
        </div>
    </main>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
