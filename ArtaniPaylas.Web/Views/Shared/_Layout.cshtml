@{
    var isAuthenticated = User?.Identity?.IsAuthenticated == true;
    var isAuthArea = Context.Request.Path.StartsWithSegments("/Identity/Account", StringComparison.OrdinalIgnoreCase);
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Artanı Paylaş</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ArtaniPaylas.Web.styles.css" asp-append-version="true" />
</head>
<body class="ap-body d-flex flex-column min-vh-100" data-authenticated="@(isAuthenticated ? "true" : "false")">
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg ap-navbar border-bottom">
            <div class="container-xxl">
                <a class="navbar-brand ap-brand" asp-controller="Home" asp-action="Index">
                    <span class="ap-brand-dot"></span>
                    <span>Artanı Paylaş</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Gezinmeyi aç/kapat">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    @if (isAuthenticated)
                    {
                        <ul class="navbar-nav ap-nav-links mx-lg-auto mb-2 mb-lg-0 ap-nav-center">
                            <li class="nav-item"><a class="nav-link" asp-controller="Listings" asp-action="Index">İlanlar</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Listings" asp-action="Create">İlan Ekle</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Listings" asp-action="MyListings">İlanlarım</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Requests" asp-action="Incoming">Gelen Talepler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Requests" asp-action="Outgoing">Giden Talepler</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Profile" asp-action="History">Geçmiş</a></li>
                        </ul>
                    }

                    <div class="ap-auth-area ms-lg-3">
                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <div class="container-xxl py-4 pb-5 d-flex flex-column flex-grow-1">
        @if (TempData["SuccessMessage"] is string successMessage)
        {
            <div class="alert alert-success ap-alert" role="alert">
                <strong>Başarılı:</strong> @successMessage
            </div>
        }
        @if (TempData["ErrorMessage"] is string errorMessage)
        {
            <div class="alert alert-danger ap-alert" role="alert">
                <strong>Uyarı:</strong> @errorMessage
            </div>
        }

        <main role="main" class="ap-main-content flex-grow-1">
            @RenderBody()
        </main>

        <div id="ap-live-toast" class="ap-live-toast" role="status" aria-live="polite"></div>
    </div>

    <footer class="ap-footer border-top mt-auto">
        <div class="container-xxl py-5">
            <div class="row g-4">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <span class="ap-brand-dot"></span>
                        <strong class="h5 mb-0">Artanı Paylaş</strong>
                    </div>
                    <p class="mb-2 text-muted">
                        Fazla gıdayı ihtiyaç sahiplerine güvenli ve saygın bir şekilde ulaştırmak için dijital dayanışma ağı.
                    </p>
                </div>

                <div class="col-lg-4">
                    <h3 class="h6 text-uppercase text-muted mb-3">Hızlı Erişim</h3>
                    <div class="d-flex flex-column gap-2 ap-footer-links">
                        <a asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        <a asp-controller="Listings" asp-action="Index">İlanları İncele</a>
                        <a asp-controller="Listings" asp-action="Create">İlan Oluştur</a>
                        <a asp-controller="Profile" asp-action="History">Geçmiş İşlemler</a>
                    </div>
                </div>

                <div class="col-lg-4">
                    <h3 class="h6 text-uppercase text-muted mb-3">Durum ve Hedef</h3>
                    <ul class="list-unstyled small text-muted mb-3">
                        <li>Misyon: Gıda israfını azaltmak</li>
                        <li>Vizyon: Güvenli ve ölçeklenebilir dayanışma</li>
                        <li>Öncelik: Hızlı eşleşme, şeffaf süreç</li>
                    </ul>
                </div>
            </div>

            <div class="ap-footer-bottom d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-2 mt-4 pt-3 border-top">
                <span>&copy; 2026 Artanı Paylaş</span>
                <span class="text-muted">Toplumsal fayda için geliştirilmektedir.</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
