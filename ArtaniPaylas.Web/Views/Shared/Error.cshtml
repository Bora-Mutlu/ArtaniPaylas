@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<section class="ap-page-head">
    <div>
        <h1 class="ap-title text-danger">Bir hata oluţtu</h1>
        <p class="ap-subtitle">Ýţleminiz tamamlanamadý. Lütfen tekrar deneyin.</p>
    </div>
</section>

<div class="ap-card p-4">
    @if (Model.ShowRequestId)
    {
        <p class="mb-2"><strong>Ýstek Kimliđi:</strong> <code>@Model.RequestId</code></p>
    }

    <p class="mb-0 text-muted">Sorun devam ederse bu kimlikle teknik kayýtlarý inceleyebiliriz.</p>
</div>
