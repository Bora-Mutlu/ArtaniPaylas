@model ListingsIndexViewModel
@using System.Security.Claims
@{
    ViewData["Title"] = "İlanlar";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    Layout = isAuthenticated ? "_UserLayout" : "_Layout";
}

@if (isAuthenticated)
{
    var totalCount = Model.Listings.Count;
    var activeCount = Model.Listings.Count(x => x.Status == ListingStatus.Active);
    var completedCount = Model.Listings.Count(x => x.Status == ListingStatus.Completed);
    var expiringSoonCount = Model.Listings.Count(x => x.Status == ListingStatus.Active && x.ExpirationDate.Date <= DateTime.UtcNow.Date.AddDays(3));

    <section class="ap-page-head">
        <div>
            <h1 class="ap-title">Tüm İlanlar</h1>
            <p class="ap-subtitle">Dashboard görünümünde tüm ilanları filtreleyebilir ve detayları hızlıca açabilirsin.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="MyListings" class="btn ap-btn-outline">İlanlarım</a>
            <a asp-action="Create" class="btn ap-btn-primary">+ Yeni İlan</a>
        </div>
    </section>

    <div class="row g-3 mb-4">
        <div class="col-md-6 col-xl-3">
            <div class="ap-card p-3 h-100">
                <small class="text-uppercase text-muted fw-semibold">Toplam İlan</small>
                <div class="h4 mt-2 mb-0">@totalCount</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="ap-card p-3 h-100">
                <small class="text-uppercase text-muted fw-semibold">Aktif</small>
                <div class="h4 mt-2 mb-0 text-success">@activeCount</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="ap-card p-3 h-100">
                <small class="text-uppercase text-muted fw-semibold">Tamamlanan</small>
                <div class="h4 mt-2 mb-0 text-primary">@completedCount</div>
            </div>
        </div>
        <div class="col-md-6 col-xl-3">
            <div class="ap-card p-3 h-100">
                <small class="text-uppercase text-muted fw-semibold">3 Gün İçinde Biten</small>
                <div class="h4 mt-2 mb-0 text-warning">@expiringSoonCount</div>
            </div>
        </div>
    </div>

    <div class="ap-card p-4 mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label asp-for="Filter.SearchTitle" class="form-label fw-semibold">Başlık</label>
                <input asp-for="Filter.SearchTitle" class="form-control" placeholder="Örn: Kışlık mont" />
            </div>
            <div class="col-lg-4">
                <label asp-for="Filter.SearchLocation" class="form-label fw-semibold">Konum</label>
                <input asp-for="Filter.SearchLocation" class="form-control" placeholder="Örn: Kadıköy" />
            </div>
            <div class="col-lg-2">
                <div class="form-check mt-4">
                    <input asp-for="Filter.ActiveOnly" class="form-check-input" />
                    <label asp-for="Filter.ActiveOnly" class="form-check-label">Sadece aktif</label>
                </div>
            </div>
            <div class="col-lg-2 d-grid">
                <button type="submit" class="btn ap-btn-outline">Filtrele</button>
            </div>
        </form>
    </div>

    @if (!Model.Listings.Any())
    {
        <div class="ap-empty">Filtre kriterlerine uygun ilan bulunamadı.</div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var listing in Model.Listings)
            {
                var canReport = currentUserId != listing.OwnerUserId;
                var statusClass = listing.Status switch
                {
                    ListingStatus.Active => "ap-pill ap-pill-active",
                    ListingStatus.Completed => "ap-pill ap-pill-completed",
                    ListingStatus.Expired => "ap-pill ap-pill-danger",
                    _ => "ap-pill ap-pill-pending"
                };

                <div class="col-md-6 col-xl-4">
                    <article class="ap-card p-3 h-100 d-flex flex-column gap-3">
                        <div class="d-flex align-items-center justify-content-between">
                            <span class="@statusClass">@listing.Status.ToDisplayText()</span>
                            <small class="text-muted">@listing.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy")</small>
                        </div>

                        <div>
                            <h2 class="h5 mb-1">@listing.Title</h2>
                            <p class="mb-1 text-muted">@listing.Location</p>
                            <small class="text-muted">Son Tarih: @listing.ExpirationDate.ToString("dd.MM.yyyy")</small>
                            <div class="mt-2">
                                <small class="text-muted">İlan Sahibi: @(listing.OwnerUser?.FullName ?? listing.OwnerUser?.UserName ?? "Kullanıcı")</small>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(listing.PhotoPath))
                        {
                            <img src="@listing.PhotoPath" class="w-100 rounded-3" style="height: 170px; object-fit: cover;" alt="@listing.Title" />
                        }

                        <div class="d-flex align-items-center justify-content-between mt-auto">
                            <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-sm ap-btn-outline">Detaya Git</a>

                            @if (canReport)
                            {
                                <details>
                                    <summary class="btn btn-sm btn-outline-danger">Şikayet Et</summary>
                                    <form asp-action="Report" method="post" class="mt-2 d-flex flex-column gap-2" onclick="event.stopPropagation();">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@listing.Id" />
                                        <input type="hidden" name="returnUrl" value="@($"{Context.Request.Path}{Context.Request.QueryString}")" />
                                        <textarea name="reason" class="form-control form-control-sm ap-no-resize" rows="2" maxlength="500" placeholder="Şikayet nedeninizi yazın" required></textarea>
                                        <button type="submit" class="btn btn-sm btn-danger">Raporla</button>
                                    </form>
                                </details>
                            }
                        </div>
                    </article>
                </div>
            }
        </div>
    }
}
else
{
    <style>
        .lp-hero {
            border: 1px solid #d9ebe1;
            border-radius: 1.75rem;
            padding: 2.25rem;
            background:
                radial-gradient(700px 300px at 90% 0%, rgba(104, 219, 169, 0.28), transparent 75%),
                linear-gradient(155deg, #ffffff 0%, #f4fbf7 100%);
            box-shadow: 0 18px 40px rgba(0, 108, 74, 0.08);
        }

        .lp-title {
            margin: 0;
            font-size: clamp(1.8rem, 3vw, 2.8rem);
            font-weight: 800;
            letter-spacing: -0.02em;
            color: #12422f;
        }

        .lp-title strong {
            color: #006948;
        }

        .lp-subtitle {
            margin: 0.75rem 0 0;
            color: #476154;
            max-width: 60ch;
        }

        .lp-btn-primary {
            border: 0;
            border-radius: 999px;
            font-weight: 700;
            padding: 0.7rem 1.2rem;
            color: #ffffff;
            background: linear-gradient(135deg, #006948 0%, #00855d 100%);
            box-shadow: 0 12px 24px rgba(0, 108, 74, 0.28);
        }

        .lp-btn-primary:hover {
            color: #ffffff;
            background: linear-gradient(135deg, #005236 0%, #006948 100%);
        }

        .lp-filter-card {
            border: 1px solid #d9ebe1;
            border-radius: 1.25rem;
            padding: 1rem;
            background: #ffffff;
            box-shadow: 0 10px 24px rgba(16, 66, 47, 0.08);
        }

        .lp-filter-card .form-label {
            color: #2f4d3f;
            font-weight: 700;
        }

        .lp-filter-card .form-control {
            border-radius: 0.85rem;
            border-color: #c4e1d0;
            padding: 0.65rem 0.85rem;
        }

        .lp-filter-card .form-control:focus {
            border-color: #4edea3;
            box-shadow: 0 0 0 0.2rem rgba(0, 108, 74, 0.15);
        }

        .lp-btn-outline {
            border-radius: 0.85rem;
            border: 1px solid #97d8b3;
            color: #005236;
            font-weight: 700;
            background: #ecf9f2;
        }

        .lp-btn-outline:hover {
            color: #ffffff;
            background: #006948;
            border-color: #006948;
        }

        .lp-listing-card {
            border: 1px solid #d9ebe1;
            border-radius: 1.15rem;
            background: #ffffff;
            box-shadow: 0 12px 26px rgba(15, 45, 33, 0.08);
            transition: transform 0.18s ease, box-shadow 0.18s ease;
        }

        .lp-listing-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 34px rgba(15, 45, 33, 0.12);
        }

        .lp-photo-wrap {
            height: 220px;
            position: relative;
            border-radius: 1.15rem 1.15rem 0 0;
            overflow: hidden;
            background: #f4f7f5;
        }

        .lp-photo-wrap img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .lp-photo-fallback {
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #647b6f;
            font-weight: 600;
        }

        .lp-badge {
            position: absolute;
            top: 0.85rem;
            left: 0.85rem;
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.02em;
            padding: 0.35rem 0.65rem;
            border-radius: 999px;
            border: 1px solid transparent;
        }

        .lp-badge-active {
            color: #0b5136;
            background: #d8f8e8;
            border-color: #9de8c5;
        }

        .lp-badge-completed {
            color: #5b4235;
            background: #fbe6da;
            border-color: #f0c7b1;
        }

        .lp-badge-danger {
            color: #8b1111;
            background: #ffe0dc;
            border-color: #f7b5ab;
        }

        .lp-badge-pending {
            color: #24473a;
            background: #e7f1ec;
            border-color: #c6dbd1;
        }

        .lp-meta {
            color: #476154;
            font-size: 0.92rem;
        }

        .lp-detail-btn {
            border-radius: 0.75rem;
            border: 1px solid #a9dac1;
            color: #005236;
            font-weight: 700;
            background: #f0faf5;
        }

        .lp-detail-btn:hover {
            color: #ffffff;
            background: #006948;
            border-color: #006948;
        }

        .lp-report-toggle {
            border-radius: 0.7rem;
            border: 1px solid #efb8b8;
            color: #8b1111;
            background: #fff0f0;
            font-size: 0.82rem;
            font-weight: 700;
            padding: 0.35rem 0.6rem;
            display: inline-block;
            cursor: pointer;
        }

        .lp-report-toggle:hover {
            background: #ffe0e0;
        }

        .lp-report-box {
            border: 1px dashed #efb8b8;
            border-radius: 0.85rem;
            padding: 0.75rem;
            background: #fff9f9;
        }

        .lp-empty {
            border: 1px dashed #b8d8c7;
            border-radius: 1rem;
            padding: 1rem;
            text-align: center;
            background: #f6fcf9;
            color: #4a6156;
            font-weight: 600;
        }
    </style>

    <section class="lp-hero mb-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-4">
        <div>
            <h1 class="lp-title">Aktif <strong>giysi ilanları</strong></h1>
            <p class="lp-subtitle">Konum ve başlığa göre filtrele, ihtiyacına uygun ilanı hızlıca bul ve güvenle talep gönder.</p>
        </div>
        <a asp-action="Create" class="btn lp-btn-primary">+ Yeni İlan</a>
    </section>

    <section class="lp-filter-card mb-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-lg-4">
                <label asp-for="Filter.SearchTitle" class="form-label">Başlık</label>
                <input asp-for="Filter.SearchTitle" class="form-control" placeholder="Örn: Kışlık mont" />
            </div>
            <div class="col-lg-4">
                <label asp-for="Filter.SearchLocation" class="form-label">Konum</label>
                <input asp-for="Filter.SearchLocation" class="form-control" placeholder="Örn: Kadıköy" />
            </div>
            <div class="col-lg-2">
                <div class="form-check mt-4 pt-1">
                    <input asp-for="Filter.ActiveOnly" class="form-check-input" />
                    <label asp-for="Filter.ActiveOnly" class="form-check-label fw-semibold">Sadece aktif</label>
                </div>
            </div>
            <div class="col-lg-2 d-grid">
                <button type="submit" class="btn lp-btn-outline">Filtrele</button>
            </div>
        </form>
    </section>

    @if (!Model.Listings.Any())
    {
        <div class="lp-empty">Filtre kriterlerine uygun ilan bulunamadı.</div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var listing in Model.Listings)
            {
                var statusClass = listing.Status switch
                {
                    ListingStatus.Active => "lp-badge-active",
                    ListingStatus.Completed => "lp-badge-completed",
                    ListingStatus.Expired => "lp-badge-danger",
                    _ => "lp-badge-pending"
                };

                <div class="col-sm-6 col-xl-4">
                    <article class="lp-listing-card h-100 overflow-hidden">
                        <div class="lp-photo-wrap">
                            @if (!string.IsNullOrWhiteSpace(listing.PhotoPath))
                            {
                                <img src="@listing.PhotoPath" alt="@listing.Title" />
                            }
                            else
                            {
                                <div class="lp-photo-fallback">Fotoğraf yok</div>
                            }
                            <span class="@statusClass lp-badge">@listing.Status.ToDisplayText()</span>
                        </div>

                        <div class="p-4 d-flex flex-column gap-3">
                            <div>
                                <h2 class="h5 mb-1">@listing.Title</h2>
                                <p class="lp-meta mb-1">Konum: @listing.Location</p>
                                <p class="lp-meta mb-0">Son Tarih: @listing.ExpirationDate.ToString("dd.MM.yyyy")</p>
                            </div>

                            <div class="d-flex align-items-center justify-content-between mt-auto">
                                <a asp-action="Details" asp-route-id="@listing.Id" class="btn btn-sm lp-detail-btn">Detaya Git</a>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    }
}
