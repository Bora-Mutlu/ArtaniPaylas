@model ListingCreateEditViewModel
@{
    ViewData["Title"] = "İlan Ekle";
    Layout = "_UserLayout";
}

<section class="ap-page-head">
    <div>
        <h1 class="ap-title">Yeni İlan Oluştur</h1>
        <p class="ap-subtitle">Paylaşmak istediğin giysiyi birkaç adımda yayınla.</p>
    </div>
    <a asp-action="MyListings" class="btn ap-btn-outline">İlanlarıma Dön</a>
</section>

<div class="row g-4">
    <div class="col-xl-8">
        <form asp-action="Create" method="post" enctype="multipart/form-data" class="space-y-4">
            <partial name="_Form" model="Model" />
            <div class="d-flex gap-2">
                <button class="btn ap-btn-primary" type="submit">İlanı Yayınla</button>
                <a asp-action="MyListings" class="btn ap-btn-outline">İptal</a>
            </div>
        </form>
    </div>

    <div class="col-xl-4">
        <div class="ap-card p-4 mb-3">
            <h2 class="h6 fw-bold mb-3">Hızlı Kontrol Listesi</h2>
            <ul class="mb-0 ps-3 text-muted">
                <li>Başlığı net ve kısa yaz.</li>
                <li>Açıklamada ürün durumu ve beden bilgisini belirt.</li>
                <li>Son tarihi gerçekçi girerek talepleri hızlandır.</li>
                <li>Konumu doğru seçerek uygun eşleşme yakala.</li>
            </ul>
        </div>

        <div class="ap-card p-4">
            <h2 class="h6 fw-bold mb-2">Öneri</h2>
            <p class="mb-0 text-muted">Fotoğrafı gün ışığında çekmek ve ürünün tamamını göstermek, talep alma oranını artırır.</p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

