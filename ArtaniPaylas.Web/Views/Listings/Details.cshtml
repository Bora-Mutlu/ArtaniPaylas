@model Listing
@using System.Security.Claims
@{
    ViewData["Title"] = "İlan Detayı";
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    Layout = isAuthenticated ? "_UserLayout" : "_Layout";
    var isOwner = currentUserId == Model.OwnerUserId;
    var canRequest = isAuthenticated && !isOwner && Model.Status == ListingStatus.Active;
    var canReport = isAuthenticated && !isOwner;

    var statusClass = Model.Status switch
    {
        ListingStatus.Active => "ap-pill ap-pill-active",
        ListingStatus.Completed => "ap-pill ap-pill-completed",
        ListingStatus.Expired => "ap-pill ap-pill-danger",
        _ => "ap-pill ap-pill-pending"
    };
}

<section class="ap-page-head">
    <div>
        <h1 class="ap-title">@Model.Title</h1>
        <p class="ap-subtitle">@Model.Location</p>
    </div>
    <a asp-action="Index" class="btn ap-btn-outline">İlanlara Dön</a>
</section>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="ap-card p-4 h-100">
            <p class="mb-3">@Model.Description</p>
            <div class="d-flex flex-column gap-2 text-slate-700">
                <div><strong>Son Tüketim:</strong> @Model.ExpirationDate.ToString("dd.MM.yyyy")</div>
                <div><strong>Durum:</strong> <span class="@statusClass">@Model.Status.ToDisplayText()</span></div>
                <div><strong>İlan Sahibi:</strong> @(Model.OwnerUser?.FullName ?? Model.OwnerUser?.UserName ?? "Kullanıcı")</div>
            </div>

            <div class="mt-4">
                @if (canRequest)
                {
                    <form asp-controller="Requests" asp-action="Create" method="post">
                        <input type="hidden" name="listingId" value="@Model.Id" />
                        <button type="submit" class="btn ap-btn-primary">Talep Et</button>
                    </form>
                }
                else if (!isAuthenticated)
                {
                    <div class="ap-empty">Talep göndermek için giriş yapmalısın.</div>
                }
            </div>

            @if (canReport)
            {
                <div class="mt-4 pt-3 border-top">
                    <h3 class="h6 fw-bold mb-2">İlanı Şikayet Et</h3>
                    <form asp-action="Report" method="post" class="d-flex flex-column gap-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@($"/Listings/Details/{Model.Id}")" />
                        <textarea name="reason" class="form-control ap-no-resize" rows="3" maxlength="500" placeholder="Şikayet nedeninizi yazın" required></textarea>
                        <button type="submit" class="btn btn-danger align-self-start">Şikayet Et</button>
                    </form>
                </div>
            }
        </div>
    </div>

    <div class="col-lg-5">
        <div class="ap-card p-3 h-100">
            @if (!string.IsNullOrWhiteSpace(Model.PhotoPath))
            {
                <img src="@Model.PhotoPath" class="img-fluid rounded-3" alt="@Model.Title" style="max-height: 360px; width: 100%; object-fit: cover;" />
            }
            else
            {
                <div class="d-flex justify-content-center align-items-center h-100 bg-light rounded-3 text-muted">Fotoğraf eklenmemiş</div>
            }
        </div>
    </div>
</div>

@if (isOwner)
{
    <section class="ap-section">
        <div class="ap-page-head mb-3">
            <div>
                <h2 class="h4 mb-0">Gelen Talepler</h2>
                <p class="ap-subtitle">Bu ilana gelen talepleri buradan takip edebilirsin.</p>
            </div>
        </div>

        @if (!Model.Requests.Any())
        {
            <div class="ap-empty">Bu ilana henüz talep gelmedi.</div>
        }
        else
        {
            <div class="ap-card p-3">
                <div class="table-responsive">
                    <table class="table align-middle mb-0 ap-table">
                        <thead>
                            <tr>
                                <th>Kullanıcı</th>
                                <th>Durum</th>
                                <th>Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var request in Model.Requests.OrderByDescending(x => x.CreatedAt))
                        {
                            <tr>
                                <td>@(request.RequesterUser?.FullName ?? request.RequesterUser?.UserName ?? "Kullanıcı")</td>
                                <td>@request.Status.ToDisplayText()</td>
                                <td>@request.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </section>
}
