@model ArtaniPaylas.Core.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<style>
    .slide-in-left {
        animation: slideInLeft 0.5s ease-out forwards;
    }
    .slide-in-right {
        animation: slideInRight 0.5s ease-out forwards;
    }
    @@keyframes slideInLeft {
        from { opacity: 0; transform: translateX(-30px); }
        to { opacity: 1; transform: translateX(0); }
    }
    @@keyframes slideInRight {
        from { opacity: 0; transform: translateX(30px); }
        to { opacity: 1; transform: translateX(0); }
    }
    .ap-auth-visual {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
</style>

<section class="ap-auth-wrap">
    <div class="container py-4 py-lg-5">
        <div class="ap-auth-shell mx-auto">
            <!-- GİRİŞ FORMU SOLDA -->
            <div class="ap-auth-card p-4 p-md-5 slide-in-left">
                <header class="ap-auth-header mb-4">
                    <span class="ap-auth-eyebrow text-primary fw-bold">Oturum Açın</span>
                    <h1 class="ap-auth-title h2 mb-2">Hoş Geldiniz</h1>
                    <p class="text-muted mb-0">E-posta ve şifrenizle giriş yapın.</p>
                </header>

                <form method="post" asp-action="Login" asp-controller="Account" asp-route-returnUrl="@ViewData["ReturnUrl"]" novalidate id="loginForm">
                    @Html.AntiForgeryToken()

                    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.TryGetValue(string.Empty, out var modelErrors) && modelErrors.Errors.Count > 0)
                    {
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger p-2 small mb-3" role="alert"></div>
                    }

                    <div class="ap-field mb-3">
                        <label asp-for="Email" class="ap-field-label fw-bold small text-secondary">E-posta Adresi</label>
                        <input asp-for="Email" type="email" class="form-control py-2" maxlength="120" autocomplete="email" placeholder="ornek@mail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="ap-field mb-4">
                        <label asp-for="Password" class="ap-field-label fw-bold small text-secondary">Şifre</label>
                        <input asp-for="Password" type="password" class="form-control py-2" id="loginPassword" autocomplete="current-password" placeholder="Şifreniz" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex align-items-center justify-content-between mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input shadow-none" type="checkbox" id="RememberMeCheck" />
                            <label class="form-check-label user-select-none" for="RememberMeCheck">Beni hatırla</label>
                        </div>
                        <a href="javascript:void(0)" class="small text-decoration-none" onclick="alert('Şifremi unuttum özelliği daha sonra aktif olacaktır.');">Şifrenizi mi unuttunuz?</a>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold text-uppercase fs-6">Giriş Yap</button>
                </form>
            </div>
            
            <!-- KAYIT BİLGİ PANELİ SAĞDA -->
            <aside class="ap-auth-visual slide-in-right text-center" aria-hidden="true">
                <span class="ap-auth-eyebrow text-uppercase fw-bold text-success d-inline-block mb-2">Artanı Paylaş</span>
                <h2 class="ap-auth-visual-title h2 text-dark mt-3">Yeni misiniz?</h2>
                <p class="ap-auth-visual-text text-secondary mt-3 mb-4">Giysi israfını önlemek ve topluluğa destek olmak için hemen bir hesap oluşturun.</p>
                
                <div class="mt-2 text-center">
                    <p class="mb-3 small text-dark fw-bold">Hesabınız yok mu?</p>
                    <a href="/Account/Register?returnUrl=@Model.ReturnUrl" class="btn btn-success rounded-pill px-5 py-2 fw-bold shadow-sm">Kayıt Ol</a>
                </div>
            </aside>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
}


